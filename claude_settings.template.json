{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pre-send-review.py"
          }
        ],
        "description": "GFV Voice/Quality Gate Check before sending communications or finalizing emails"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/session-stop.py --log || true"
          }
        ],
        "description": "Update GFV sync logs periodically"
      }
    ]
  }
}
